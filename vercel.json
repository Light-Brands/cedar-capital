{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "framework": "nextjs",
  "buildCommand": "npm run build",
  "installCommand": "npm install",
  "crons": [
    { "path": "/api/cron/discover/rentcast", "schedule": "0 */2 * * *" },
    { "path": "/api/cron/discover/realty_in_us", "schedule": "5 */2 * * *" },
    { "path": "/api/cron/discover/realtor16", "schedule": "10 */2 * * *" },
    { "path": "/api/cron/enrich", "schedule": "25 */2 * * *" },
    { "path": "/api/cron/analyze", "schedule": "40 */2 * * *" },
    { "path": "/api/cron/outreach", "schedule": "55 */2 * * *" }
  ],
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        {
          "key": "X-Content-Type-Options",
          "value": "nosniff"
        },
        {
          "key": "X-Frame-Options",
          "value": "DENY"
        },
        {
          "key": "X-XSS-Protection",
          "value": "1; mode=block"
        },
        {
          "key": "Referrer-Policy",
          "value": "strict-origin-when-cross-origin"
        }
      ]
    },
    {
      "source": "/fonts/(.*)",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "public, max-age=31536000, immutable"
        }
      ]
    }
  ]
}
